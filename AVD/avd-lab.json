    {
      "condition": "[parameters('enableMonitoring')]",
      "type": "Microsoft.Insights/scheduledQueryRules",
      "apiVersion": "2022-06-15",
      "name": "[format('{0}-alert-host-unavailable', parameters('prefix'))]",
      "location": "[parameters('location')]",
      "tags": "[variables('tags')]",
      "properties": {
        "displayName": "AVD Session Host Unavailable",
        "description": "Alerts when a session host reports as unavailable",
        "severity": 2,
        "enabled": true,
        "scopes": [
          "[if(parameters('enableMonitoring'), resourceId('Microsoft.OperationalInsights/workspaces', parameters('logAnalyticsWorkspaceName')), resourceGroup().id)]"
        ],
        "evaluationFrequency": "PT5M",
        "windowSize": "PT15M",
        "criteria": {
          "allOf": [
            {
              "query": "WVDAgentHealthStatus | where Status != \"Available\" | summarize count() by SessionHostName",
              "timeAggregation": "Count",
              "operator": "GreaterThan",
              "threshold": 0,
              "failingPeriods": {
                "numberOfEvaluationPeriods": 1,
                "minFailingPeriodsToAlert": 1
              }
            }
          ]
        },
        "actions": {
          "actionGroups": "[if(and(parameters('enableMonitoring'), not(empty(parameters('alertEmailAddress')))), createArray(resourceId('Microsoft.Insights/actionGroups', format('{0}-ag', parameters('prefix')))), createArray())]"
        }
      },
      "dependsOn": [
        "[resourceId('Microsoft.Insights/actionGroups', format('{0}-ag', parameters('prefix')))]",
        "[resourceId('Microsoft.OperationalInsights/workspaces', parameters('logAnalyticsWorkspaceName'))]"
      ]
    },
    {
